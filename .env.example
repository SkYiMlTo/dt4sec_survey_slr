# Environment variables for the SLR pipeline
# Copy this file to .env and fill in your keys.
# The pipeline will still run (with limited sources) if keys are absent.

# ── Optional API keys ─────────────────────────────────────────────────────────

# IEEE Xplore REST API key (free — register at https://developer.ieee.org/)
# Without this, IEEE Xplore extraction is skipped.
IEEE_API_KEY=

# Springer Nature Open Access API key (free — register at https://dev.springernature.com/)
# Without this, Springer extraction falls back to Selenium scraping.
SPRINGER_API_KEY=

# Semantic Scholar API key (optional — register at https://www.semanticscholar.org/product/api)
# Without this, the public rate limit (1 req/s) applies.
SEMANTIC_SCHOLAR_API_KEY=
